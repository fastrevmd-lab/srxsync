<configuration>
  <security>
    <address-book>
      <name>global</name>
      <address>
        <name>ADDR1</name>
        <ip-prefix>10.0.0.1/32</ip-prefix>
      </address>
    </address-book>
    <policies>
      <policy>
        <from-zone-name>trust</from-zone-name>
        <to-zone-name>untrust</to-zone-name>
        <policy>
          <name>allow-dns</name>
          <match>
            <source-address>any</source-address>
            <destination-address>any</destination-address>
            <application>junos-dns-udp</application>
          </match>
          <then><permit/></then>
        </policy>
      </policy>
    </policies>
    <nat>
      <static>
        <rule-set>
          <name>rs1</name>
          <rule>
            <name>SITE_LOCAL</name>
            <static-nat><prefix><addr-prefix>10.0.0.2/32</addr-prefix></prefix></static-nat>
          </rule>
          <rule>
            <name>COMMON</name>
            <static-nat><prefix><addr-prefix>10.0.0.3/32</addr-prefix></prefix></static-nat>
          </rule>
        </rule-set>
      </static>
    </nat>
    <zones>
      <security-zone>
        <name>trust</name>
        <interfaces><name>ge-0/0/0.0</name></interfaces>
        <host-inbound-traffic><system-services><name>ssh</name></system-services></host-inbound-traffic>
      </security-zone>
    </zones>
  </security>
</configuration>
